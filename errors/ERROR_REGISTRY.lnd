changelog:
  - version: "1.0.0"
    date: "2026-03-10"
    changes:
      - "Initial error registry creation"
      - "Documented all parse errors from grammar_contract.py"
      - "Documented all runtime errors from interpreter_runtime.py"
      - "Established E_<CATEGORY>_<DESCRIPTOR> naming convention"
      - "Defined standardized error payload schema"
