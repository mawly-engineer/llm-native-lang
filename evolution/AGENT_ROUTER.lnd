@lnd 0.2
kind: agent_router
id: ROUTER-001
status: active
updated_at_utc: 2026-03-11T00:12:00Z
purpose: Route agents to appropriate streams and manage workload distribution.

streams:
  language_core:
    description: Language specification and core capabilities
    priority: 1
    eligible_agents:
      - language_designer
      - specification_validator
    max_concurrent: 2
    current_load: 0
    
  runtime_replay:
    description: Runtime execution and replay system
    priority: 2
    eligible_agents:
      - runtime_engineer
      - replay_specialist
    max_concurrent: 2
    current_load: 0
    
  contracts:
    description: LND/LNC format contracts and validation
    priority: 3
    eligible_agents:
      - contract_validator
      - format_specialist
    max_concurrent: 2
    current_load: 0

routing_rules:
  - rule: product_core_first
    condition: item.objective in [language_core_capability, runtime_replay_capability, llm_format_contract_capability]
    priority_boost: 10
    
  - rule: language_core_before_runtime
    condition: item.category == language_core and runtime_replay has items
    action: prioritize language_core first
    
  - rule: blocked_items_last
    condition: item.has_blocker == true
    action: deprioritize and move to blocked queue

load_balancing:
  strategy: round_robin_with_capacity
  rebalance_threshold: 0.8
  cooldown_cycles: 2

agent_pool:
  language_designer:
    capabilities: [language_design, spec_authoring, grammar_definition]
    streams: [language_core]
    
  specification_validator:
    capabilities: [lnd_validation, lnc_validation, compliance_checking]
    streams: [language_core, contracts]
    
  runtime_engineer:
    capabilities: [runtime_dev, interpreter_building, builtin_implementation]
    streams: [runtime_replay]
    
  replay_specialist:
    capabilities: [replay_system, execution_tracing, deterministic_metrics]
    streams: [runtime_replay]
    
  contract_validator:
    capabilities: [lnd_validation, lnc_validation, contract_enforcement]
    streams: [contracts]
    
  format_specialist:
    capabilities: [format_design, schema_definition, migration_planning]
    streams: [contracts, language_core]
