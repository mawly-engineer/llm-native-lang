@lnd 0.2
version: 2
document: AGENT_ROUTER
purpose: Route the single coordinator to the correct specialist focus each cycle.
updated_at_utc: "2026-03-08T12:05:00Z"

operating_mode:
  scheduler_model: single_coordinator
  coordinator_executes_work_directly: true
  one_backlog_item_per_cycle: true
  dynamic_bucket_selection: true

strategic_targets:
  objective: Keep delivery anchored to product core while preserving determinism.
  dimensions:
    language-core:
      score_current: 4
      score_target: 8
    runtime-replay:
      score_current: 4
      score_target: 8
    llm-format-contract:
      score_current: 7
      score_target: 8
    ecosystem:
      score_current: 7
      score_target: 8
    practical-value:
      score_current: 6
      score_target: 8
  priority_rule: Prefer language-core and runtime-replay unless hard reliability signals force otherwise.

cycle_quota_guard:
  window_cycles: 5
  min_cycles_in_focus_set: 4
  focus_set:
    - language-core
    - runtime-replay
  enforcement_rule: "If quota is not yet met inside the current 5-cycle window and no hard reliability signal is active, force select_primary from product-core focus_set."
  tie_break_within_focus_set:
    - lowest_dimension_score
    - deterministic_bucket_name_order

meta_work_limit:
  max_meta_items_per_5_cycles: 1
  meta_categories:
    - process_only
    - pure_infra
    - log_only
  on_limit_exceeded:
    - force_select_primary: language-core_or_runtime-replay

active_selection:
  active_primary: language-core
  active_secondary: validation

routing_rules_in_priority_order:
  - id: route_integration_on_e2e_red
    when:
      signal_e2e_red: true
    select_primary: integration
    reason: "E2E instability has highest priority."

  - id: route_validation_on_test_failures
    when:
      signal_tests_or_contracts_failing: true
    select_primary: validation
    reason: "Failing assertions/contracts must be stabilized before feature expansion."

  - id: route_runtime_on_runtime_gaps
    when:
      signal_runtime_gap: true
    select_primary: interpreter-runtime
    reason: "Determinism/runtime correctness is a hard gate."

  - id: route_ecosystem_on_gap
    when:
      signal_ecosystem_gap: true
    select_primary: ecosystem
    reason: "Public usability and project adoption need focused improvement."

  - id: route_practical_value_on_gap
    when:
      signal_practical_value_gap: true
    select_primary: practical-value
    reason: "Hands-on utility and evidence must improve."

  - id: default_route_by_lowest_dimension_score
    when:
      fallback_default: true
    select_primary: lowest_score_dimension
    reason: "By default, advance whichever strategic dimension is currently weakest (ecosystem -> practical-value -> language-core)."

product_scope_gate:
  required_alignment_tags:
    - language-core
    - runtime-replay
    - llm-format-contract
  fallback_allowed_tags_when_no_product_item:
    - ecosystem-p0
  reject_if_only:
    - process_churn
    - log_churn

overrides:
  force_agent: null
  hold_agents: []

required_cycle_output_fields:
  - selected_primary
  - selected_secondary
  - executed_backlog_item_id
  - implementation_delta
  - tests
  - changed_files
  - commit
  - blockers
