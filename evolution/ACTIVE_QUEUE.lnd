@lnd 0.2
version: 35
document: ACTIVE_QUEUE
purpose: Active execution queue only (no history duplication).
updated_at_utc: 2026-03-10T02:22:00Z

queue_policy:
  max_active_steps: 5
  min_active_steps_target: 3
  max_active_steps_per_stream: 1
  step_granularity: macro
  selection_order:
    - highest_priority_backlog
    - in_progress_first
    - deterministic_step_id_order
  micro_tasks_location: evolution/WORK_ITEMS.lnd
  history_source_of_truth:
    - evolution/WORK_ITEMS.lnd
    - evolution/CYCLE_LOG.lnd

active_queue:
  - step_id: LNG-CORE-51-STEP-01
    backlog_item_id: LNG-CORE-51
    title: "Grammar und AST fuer fn-Expressions implementieren"
    stage: create
    priority: P1
    created_at_utc: "2026-03-10T02:22:00Z"
    details: |
      1. Grammar: Add _fn() method to parse 'fn' '(' params? ')' '=>' expr
      2. Tokenizer: Ensure 'fn' and '=>' are recognized as keywords/operators
      3. AST: Define 'fn' node with params (string array) and body (expr)
      4. Grammar tests: Verify parse_expr('fn(x) => x') creates correct AST
      5. Edge cases: fn() => expr (no params), fn(x, y) => expr (multiple params)
