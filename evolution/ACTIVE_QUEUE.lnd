version: 13
document: ACTIVE_QUEUE
purpose: Active execution queue only (no history duplication).
updated_at_utc: 2026-03-08T17:40:01Z

queue_policy:
  max_active_steps: 5
  min_active_steps_target: 3
  max_active_steps_per_stream: 1
  step_granularity: macro
  selection_order:
    - highest_priority_backlog
    - in_progress_first
    - deterministic_step_id_order
  micro_tasks_location: evolution/WORK_ITEMS.lnd
  history_source_of_truth:
    - evolution/WORK_ITEMS.lnd
    - evolution/CYCLE_LOG.lnd

active_queue: []
