@lnd 0.2
kind: run_profile
id: RUN-PRODUCT-CORE-004
status: active
updated_at_utc: 2026-03-09T14:30:00Z
purpose: Execute product-core cycles with DYNAMIC BATCHING.

mission:
  - advance_language_core
  - advance_runtime_replay
  - preserve_llm_format_contracts

execution_policy:
  dynamic_batching: true
  batch_time_threshold: 120
  max_items_per_cycle: 3
  prioritize_product_core_items: true
  require_preflight_before_validate: true
  require_clean_git_at_cycle_end: true
  suppress_idle_noop_commits: true
  idle_log_mode: summary_only
  enable_controlled_backlog_seeding: true
  prefer_seed_on_idle_noop: true
  enable_stage_batching_same_item: true
  stage_batch_max_transitions_per_cycle: 4
  prefer_close_item_in_single_cycle_when_safe: true
  require_full_validation_suite_each_cycle: false
  prioritize_error_path_and_negative_tests: true

backlog_seed_policy_file: evolution/runs/BACKLOG_SEED_RULES.lnd

# DYNAMIC BATCHING: Process multiple items if time allows
batching_commands:
  - python3 scripts/smart_batching.py

validator_commands:
  - python3 validate_incremental.py
  - python3 scripts/detect_changes.py --mark

smart_validation_config:
  enabled: true
  mode: incremental
  change_detection: scripts/detect_changes.py
  incremental_validator: validate_incremental.py
  skip_if_no_changes: true
  mark_good_after_success: true

gate_profile:
  file: evolution/cron/INTERNAL_VALIDATION_GATE.lnd
  mode: internal_local_first

maintenance_commands:
  - python3 scripts/cycle_log_maintain.py --repo /home/node/.openclaw/workspace/llm-native-lang --max-entries 20
  - python3 scripts/work_items_compact.py
  - python3 scripts/metrics_dashboard.py

maintenance_enforcement:
  run_timing: every_n_cycles
  run_every_n_cycles: 10
  require_post_maintenance_git_check: true
  auto_commit_if_only_maintenance_diffs: true
  maintenance_diff_paths:
    - evolution/CYCLE_LOG.lnd
    - evolution/WORK_ITEMS.lnd
    - evolution/WORK_COMPLETED_ARCHIVE.lnd
  maintenance_commit_gate:
    require_one_of:
      - new_cycle_log_entry_with_meaningful_change
      - new_archive_item_added
      - work_items_status_changed
    forbid_if_only:
      - timestamp_only_changes
      - formatting_only_changes
      - idle_noop_touches
  auto_commit_message: "maintenance: normalize cycle/work logs"
  on_non_maintenance_dirty_tree:
    - add_blocker: working_tree_not_clean
    - skip_stage_transition

git_policy:
  fetch_frequency: every_n_cycles
  fetch_every_n_cycles: 3
  gc_auto: true
  gc_auto_threshold: 256
  commands:
    - git fetch --all --prune
    - if_fetch_fails_retry_once_after_5s
    - if_second_fetch_fails_set_blocker_git_fetch_failed_and_skip_execution
    - git checkout main
    - git pull --ff-only origin main
    - commit_and_push_if_changed

performance_optimizations:
  version: "2025-03-09-dynamic-batch"
  changes:
    - "Dynamic Batching: multiple items per cycle if time allows"
    - "Git repo optimized: gc --aggressive (13M -> 864K)"
    - "Incremental validation: only changed files -> specific tests"
    - "Git fetch: every 3 cycles"
    - "Pre-commit hooks for local validation"
    - "Metrics dashboard for cycle tracking"
    - "Smart change detection with domain mapping"
