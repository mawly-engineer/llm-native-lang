@lnd 0.2
kind: run_profile
id: RUN-PRODUCT-CORE-001
status: active
updated_at_utc: 2026-03-08T01:23:00Z
purpose: Execute product-core language/runtime evolution cycles.

mission:
  - advance_language_core
  - advance_runtime_replay
  - preserve_llm_format_contracts

execution_policy:
  one_unit_per_cycle: true
  prioritize_product_core_items: true
  require_preflight_before_validate: true
  require_clean_git_at_cycle_end: true
  suppress_idle_noop_commits: true
  idle_log_mode: summary_only
  enable_controlled_backlog_seeding: true

backlog_seed_policy_file: evolution/runs/BACKLOG_SEED_RULES.lnd

validator_commands:
  - python3 scripts/lnd_validate.py evolution
  - python3 scripts/lnc_validate.py runtime

gate_profile:
  file: evolution/cron/INTERNAL_VALIDATION_GATE.lnd
  mode: internal_local_first

maintenance_commands:
  - python3 scripts/cycle_log_maintain.py --repo /home/node/.openclaw/workspace/llm-native-lang --max-entries 120

git_policy:
  - git fetch --all --prune
  - git checkout main
  - git pull --ff-only origin main
  - commit_and_push_if_changed
