@lnd 0.2
kind: run_profile
id: RUN-PRODUCT-CORE-001
status: active
updated_at_utc: 2026-03-08T08:03:00Z
purpose: Execute product-core language/runtime evolution cycles.

mission:
  - advance_language_core
  - advance_runtime_replay
  - preserve_llm_format_contracts

execution_policy:
  one_unit_per_cycle: true
  prioritize_product_core_items: true
  require_preflight_before_validate: true
  require_clean_git_at_cycle_end: true
  suppress_idle_noop_commits: true
  idle_log_mode: summary_only
  enable_controlled_backlog_seeding: true
  prefer_seed_on_idle_noop: true

backlog_seed_policy_file: evolution/runs/BACKLOG_SEED_RULES.lnd

validator_commands:
  - python3 scripts/lnd_validate.py evolution
  - python3 scripts/lnc_validate.py runtime

gate_profile:
  file: evolution/cron/INTERNAL_VALIDATION_GATE.lnd
  mode: internal_local_first

maintenance_commands:
  - python3 scripts/cycle_log_maintain.py --repo /home/node/.openclaw/workspace/llm-native-lang --max-entries 20
  - python3 scripts/work_items_compact.py

maintenance_enforcement:
  run_timing: end_of_every_cycle
  require_post_maintenance_git_check: true
  auto_commit_if_only_maintenance_diffs: true
  maintenance_diff_paths:
    - evolution/CYCLE_LOG.lnd
    - evolution/WORK_ITEMS.lnd
    - evolution/WORK_COMPLETED_ARCHIVE.lnd
  auto_commit_message: "maintenance: normalize cycle/work logs"
  on_non_maintenance_dirty_tree:
    - add_blocker: working_tree_not_clean
    - skip_stage_transition

git_policy:
  - git fetch --all --prune
  - if_fetch_fails_retry_once_after_5s
  - if_second_fetch_fails_set_blocker_git_fetch_failed_and_skip_execution
  - git checkout main
  - git pull --ff-only origin main
  - commit_and_push_if_changed
