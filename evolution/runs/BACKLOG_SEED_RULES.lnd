@lnd 0.2
kind: backlog_seed_policy
id: SEED-RULES-001
status: active
updated_at_utc: 2026-03-10T10:52:00Z
purpose: Rules for controlled backlog seeding after sustained idle streaks.

seed_conditions:
  - condition: all_product_core_items_done
    threshold_cycles: 1
    action: seed_next_product_core_item

creation_rules:
  - rule: seed_only_product_core_when_language_core_complete
    priority: P1
    target_bucket: ecosystem

governance:
  max_seeds_per_cycle: 1
  require_explicit_backlog_item_id: true
