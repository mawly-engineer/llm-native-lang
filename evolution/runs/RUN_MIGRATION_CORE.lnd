@lnd 0.2
kind: run_profile
id: RUN-MIGRATION-CORE-001
status: active
updated_at_utc: 2026-03-07T15:54:00Z
purpose: Execute migration-focused evolution cycles.

mission:
  - execute_migration_plan
  - enforce_lnd_lnc_split
  - minimize_file_sprawl

primary_plan_file: evolution/MIGRATION_TO_LND_LNC.lnd

execution_policy:
  one_unit_per_cycle: true
  prioritize_migration_items: true
  use_legacy_markdown_as_source: false
  require_preflight_before_validate: true
  require_clean_git_at_cycle_end: true
  suppress_idle_noop_commits: true
  idle_log_mode: summary_only

validator_commands:
  - python3 scripts/lnd_validate.py evolution
  - python3 scripts/lnc_validate.py runtime

gate_profile:
  file: evolution/cron/INTERNAL_VALIDATION_GATE.lnd
  mode: internal_local_first

git_policy:
  - git fetch --all --prune
  - git checkout main
  - git pull --ff-only origin main
  - commit_and_push_if_changed
