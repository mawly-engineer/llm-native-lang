  - cycle_id: CYCLE-2026-03-10-0502-019
    timestamp_utc: "2026-03-10T05:02:00Z"
    agent_profile: AGENT-KAIRO-COORDINATOR-001
    run_profile: RUN-PRODUCT-CORE-004
    selected_primary: language-core
