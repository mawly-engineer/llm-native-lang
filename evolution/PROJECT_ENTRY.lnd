@lnd 0.2
kind: project_entry
id: LNG-ENTRY-001
status: active
revision: 2
updated_at_utc: 2026-03-07T14:43:00Z
purpose: Single entry file for project control with bounded file topology.

entry_policy:
  source_of_truth: this_file
  max_core_files: 12
  file_growth_rule: "Do not add a new top-level contract file if an existing domain file can be extended without ambiguity."
  split_threshold_rule: "Split only when one file contains multiple unrelated domains or exceeds maintainability constraints."

core_file_set:
  - evolution/PROJECT_ENTRY.lnd
  - formats/lnd/LND_FORMAT.lnd
  - formats/lnc/LNC_PROFILE.lnd
  - evolution/MIGRATION_TO_LND_LNC.lnd
  - evolution/AGENT_ROUTER.lnd
  - evolution/LANGUAGE_BACKLOG.lnd
  - evolution/NEXT_STEPS.lnd
  - evolution/SUPERVISOR_STATE.lnd
  - evolution/SUPERVISOR_PROFILES.lnd
  - evolution/CYCLE_LOG.lnd
  - contracts/SPEC.lnd
  - contracts/RUNTIME.lnd

agent_and_cron_control_files:
  - evolution/agents/KAIRO_COORDINATOR.lnd
  - evolution/runs/RUN_MIGRATION_CORE.lnd
  - evolution/cron/CRON_EXECUTION_PROTOCOL.lnd

broad_domain_files:
  contracts_domain:
    file: contracts/SPEC.lnd
    covers:
      - language_spec
      - type_system
      - patch_format
      - ui_diff_protocol
      - runtime_contract_references
  runtime_domain:
    file: contracts/RUNTIME.lnd
    covers:
      - runtime_api
      - replay_semantics
      - deterministic_metrics
      - execution_bridge_notes
  planning_domain:
    file: evolution/LANGUAGE_BACKLOG.lnd
    covers:
      - backlog_items
      - priorities
      - status
  execution_domain:
    file: evolution/NEXT_STEPS.lnd
    covers:
      - near_term_queue
      - mapped_steps
      - current_execution_focus

deprecation_policy:
  legacy_location: archive/legacy/
  markdown_status: removed
  markdown_rule: "Markdown files are removed from active project surface."

change_workflow:
  - update PROJECT_ENTRY.lnd if core topology changes
  - update target domain file (broad first, split only if required)
  - run lnd/lnc validators
  - append cycle/state changes only in existing control files

source_of_truth_governance:
  mutable_during_project: true
  policy:
    - "Source-of-truth files MAY be changed when resolving contradictions, improving determinism, or reducing process risk."
    - "Do not change source-of-truth semantics silently inside unrelated implementation runs."
    - "Apply source-of-truth changes as explicit governance changes (separate commit preferred)."
  required_on_each_sot_change:
    - update_updated_at_utc
    - increment_local_version_or_revision_field
    - add_changelog_entry_in_evolution/CYCLE_LOG.lnd
    - verify_backward_compatibility_or_add_migration_note
  run_safety_rule:
    - "If a staged flow is active, avoid breaking key/schema changes to files used by that active flow unless migration steps are included in the same cycle."

validator_targets:
  lnd:
    command: python3 scripts/lnd_validate.py evolution
  lnc:
    command: python3 scripts/lnc_validate.py runtime

acceptance:
  - "Project control remains understandable from PROJECT_ENTRY.lnd + core_file_set only."
  - "No uncontrolled file proliferation in evolution/."
