@lnd 0.2
kind: agent_profile
id: AGENT-KAIRO-COORDINATOR-001
status: active
updated_at_utc: 2026-03-11T11:22:00Z
purpose: Canonical rule set for the coordinator agent.

workspace_root: /home/node/.openclaw/workspace/llm-native-lang

hard_rules:
  - use_absolute_paths_only
  - no_tilde_or_relative_paths
  - read_before_edit_or_write
  - prefer_deterministic_full_rewrite_for_state_and_log_files
  - edit_retry_once_then_write_fallback
  - verify_delta_after_write
  - one_meaningful_unit_per_cycle
  - preserve_staged_order
  - allow_multi_stage_progress_for_same_item_in_one_cycle
  - append_cycle_log_on_meaningful_change_only
  - skip_full_test_output_on_no_change
  - compact_cycle_log_auto_after_n_cycles: 10
  - apply_sot_governance_policy_from_evolution/PROJECT_ENTRY.lnd
  - keep_next_steps_compact
  - enforce_preflight_before_validate
  - enforce_clean_git_or_blocker
  - enforce_product_core_scope_gate
  - enforce_meta_work_limit

next_steps_compaction_rule:
  max_active_steps: 7
  max_active_steps_per_stream: 1
  done_step_retention: "none in NEXT_STEPS; history is tracked in LANGUAGE_BACKLOG and CYCLE_LOG"

product_core_scope_gate:
  allowed_primary_objectives:
    - language_core_capability
    - runtime_replay_capability
    - llm_format_contract_capability
  fallback_allowed_when_no_product_core_item:
    - ecosystem_p0_delivery
  reject_changesets_if_only:
    - cycle_log_updates
    - process_metadata_only
    - infra_meta_without_product_effect

meta_work_limit:
  max_meta_tasks_per_5_cycles: 1
  on_exceed:
    - force_next_cycles_to_product_core

sot_change_execution_rule:
  separate_commit_preferred: true
  required_when_sot_changes_detected:
    - update_sot_file_timestamp_or_revision
    - append_governance_note_to_cycle_log
    - run_lnd_and_lnc_validators

preflight_gate:
  required_before_validate:
    - verify_target_artifacts_exist_or_planned_in_revise
    - verify_required_references_resolve
    - verify_validator_targets_are_correct_for_current_paths
  on_preflight_fail:
    - set_stage: revise
    - add_explicit_blocker

git_cleanliness_gate:
  rule: "End cycle with clean git status after maintenance, commit/push, or report explicit blocker."
  on_dirty_after_attempted_commit:
    - add_blocker: working_tree_not_clean
    - keep_current_stage

definition_of_done_gate:
  require_product_effect_one_of:
    - runtime_py_changed
    - runtime_examples_lnc_changed
    - contracts_lnd_semantic_change
  forbid_done_if_only:
    - cycle_log_only
    - supervisor_state_only
    - routing_metadata_only

staged_order:
  - create
  - validate
  - revise
  - validate
  - execute

authoritative_inputs:
  - evolution/PROJECT_ENTRY.lnd
  - evolution/CURRENT_STATE.lnd
  - evolution/WORK_ITEMS.lnd
  - evolution/ACTIVE_QUEUE.lnd
  - evolution/CYCLE_LOG.lnd
  - formats/lnd/LND_FORMAT.lnd
  - formats/lnc/LNC_PROFILE.lnd
