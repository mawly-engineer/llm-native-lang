@lnd 0.2
version: 24
document: SUPERVISOR_STATE
purpose: Persistent staged workflow state for multi-cycle supervisor ordering.
updated_at_utc: 2026-03-09T19:28:00Z

state:
  mode: staged_multi_cycle
  active_flow_id: FLOW-LNG-CORE-46
  active_bucket: language-core
  active_backlog_item_id: LNG-CORE-46
  active_next_step_id: STEP-LNG-CORE-46-VALIDATE
  current_stage: validate
  allowed_stages:
    - idle
    - create
    - validate
    - revise
    - execute
  last_stage_status: create_success
  last_error: null
  last_completed_item:
    item_id: LNG-CORE-45
    completed_at_utc: "2026-03-09T18:48:00Z"
  previous_completed_item:
    item_id: LNG-CORE-44
    completed_at_utc: "2026-03-09T17:18:00Z"

blockers: []

stage_transition_rules:
  idle_to_create:
    condition: no_eligible_item_in_selected_primary
  create_to_validate:
    condition: create_success
  validate_to_execute:
    condition: validator_status_approved
  validate_to_revise:
    condition: validator_status_needs_revision_or_rejected
  revise_to_validate:
    condition: revise_success
  execute_to_idle:
    condition: execute_stage_completed

retry_policy:
  on_stage_error: repeat_same_stage_next_cycle
  on_validation_failure: repeat_revise_validate_loop_until_approved
  max_retries: unlimited
