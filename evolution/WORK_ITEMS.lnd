@lnd 0.2
kind: work_items
version: 31
document: WORK_ITEMS
purpose: Canonical machine-readable backlog for coordinator-driven execution.
updated_at_utc: 2026-03-10T17:42:00Z

selection_policy:
  per_cycle_execution_limit: 3
  batch_by_stage_type: true
  lightweight_stages:
    - spec_update
    - doc_tweak
    - governance_note
  default_pick_order:
    - highest_priority
    - open_status
    - deterministic_id_order

allowed_status_values:
  - open
  - in_progress
  - blocked
  - done

buckets:
  language-core:
    description: Core syntax/AST/type contracts.
    items:
      - id: LNG-CORE-64
        title: Recursive let bindings (let rec) evaluation
        status: open
        priority: P1
        created_at: "2026-03-10T17:42:00Z"
        completed_at: null
        description: |
          Implement recursive let bindings evaluation. Grammar already supports
          'let rec' syntax and parser generates recursive: true field, but the
          interpreter cannot evaluate recursive functions.
          
          Example that fails:
          let rec fact = fn(n) =>
            if n == 0 then 1 else n * fact(n - 1)
          in fact(5)
          
          Expected: 120
          Actual: E_RT_AST_INVALID - unsupported expr kind: None
        acceptance:
          - AST contract validates recursive field
          - Interpreter evaluates recursive closures
          - Fix forward reference in recursive bindings
          - Tests for recursive factorial
          - Tests for mutually recursive functions
        target_files:
          - runtime/ast_contract.py
          - runtime/interpreter_runtime.py
          - runtime/test_recursive_bindings.py
      - id: LNG-CORE-62
        title: String escape sequences
        status: done
        priority: P1
        created_at: "2026-03-10T15:42:00Z"
        completed_at: "2026-03-10T16:02:00Z"
        description: Implement escape sequence processing for string literals.
        target_files:
          - runtime/lexer.py
      - id: LNG-CORE-61
        title: Optional call operator
        status: done
        priority: P1
        created_at: "2026-03-10T15:02:00Z"
        completed_at: "2026-03-10T15:32:00Z"
        description: Implement optional call operator for null-safe function invocation.
        target_files:
          - runtime/interpreter_runtime.py
      - id: LNG-CORE-60
        title: Range expressions
        status: done
        priority: P1
        created_at: "2026-03-10T13:52:00Z"
        completed_at: "2026-03-10T14:22:00Z"
        description: Implement range expressions for generating numeric sequences.
        target_files:
          - runtime/interpreter_runtime.py
      - id: LNG-CORE-59
        title: List slicing operator
        status: done
        priority: P1
        created_at: "2026-03-10T12:22:00Z"
        completed_at: "2026-03-10T13:22:00Z"
        description: Implement list slicing with Python-style slice notation.
        target_files:
          - runtime/interpreter_runtime.py
  ecosystem:
    description: Tooling, docs, release, and onboarding surface for external use.
    items:
      - id: LNG-CORE-63
        title: Error code registry with consistent naming and documentation
        status: done
        priority: P1
        created_at: "2026-03-10T16:52:00Z"
        completed_at: "2026-03-10T17:22:00Z"
        description: |
          Created centralized error code registry system with 19 error codes documented.
          E_PARSE_* (3 codes) and E_RT_* (16 codes) with validation script.
        acceptance:
          - Create errors/ERROR_REGISTRY.lnd ✅
          - Categorize errors ✅
          - Each error has documentation ✅
          - Validation script created ✅
        target_files:
          - errors/ERROR_REGISTRY.lnd (new)
          - scripts/validate_errors.py (new)
  practical-value:
    description: Real-world utility, examples, and measurable task value.
    items: []
  interpreter-runtime:
    description: Deterministic interpreter/runtime behavior.
    items: []
  validation:
    description: Tests, contracts, and property checks.
    items: []
  integration:
