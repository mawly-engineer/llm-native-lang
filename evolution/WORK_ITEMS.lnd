backlog:
  - id: ITEM-015
    title: "Create unified CLI tool for LNC validation and execution"
    objective: ecosystem_p0_delivery
    priority: p1
    status: done
    created_at_utc: 2026-03-11T14:32:00Z
    completed_at_utc: 2026-03-11T15:02:00Z
    bucket: ecosystem
    description: |
      Build a unified command-line interface that provides:
      - LNC file validation (using existing lnc_validate.py logic)
      - LNC contract execution with optional trace capture
      - Replay conformance testing for executed contracts
      - Export of execution traces to JSON
      - Batch validation of entire directories
    acceptance_criteria:
      - Single executable script: scripts/kairo_cli.py
      - Commands: validate, execute, replay-test
      - Integration with existing runtime/replay_harness.py
      - Proper exit codes (0=success, 1=validation failure, 2=execution error)
      - Help text and usage examples
    stage: create
    commit_ref: null

