@lnd 0.2
version: 18
document: WORK_ITEMS
purpose: Canonical machine-readable backlog for coordinator-driven execution.
updated_at_utc: 2026-03-09T20:38:00Z

selection_policy:
  per_cycle_execution_limit: 3
  batch_by_stage_type: true
  lightweight_stages:
    - spec_update
    - doc_tweak
    - governance_note
  default_pick_order:
    - highest_priority
    - open_status
    - deterministic_id_order

allowed_status_values:
  - open
  - in_progress
  - blocked
  - done

buckets:
  language-core:
    description: Core syntax/AST/type contracts.
    items:
      - id: LNG-CORE-48
        title: "Object literals {\"key\": expr, ...} with deterministic construction and hardened negative-path diagnostics"
        status: done
        priority: P1
        created_at_utc: "2026-03-09T20:58:00Z"
        completed_at_utc: "2026-03-09T21:48:00Z"
        scope: |
          Implement deterministic object literal construction:
          - Syntax: '{' STRING ':' expr (',' STRING ':' expr)* ','? '}'
          - Grammar: object production already defined, ensure tokenizer handles braces
          - AST: object node with entries field (array of {key: string, value: expr})
          - Runtime: evaluate entries left-to-right, collect into Python dict
          - Empty object '{}' is valid (zero entries)
          - Trailing comma allowed (deterministic grammar already supports)
          - Duplicate keys: reject at AST validation level (not runtime)
          - Keys must be string literals (not computed expressions)
          - Negative path: unclosed brace, malformed separator, non-string key
          - Type: object is a first-class value type
        acceptance_criteria:
          - "parse_expr('{\"a\": 1, \"b\": 2}') creates object node with 2 entries"
          - "parse_expr('{}') creates empty object node"
          - "parse_expr('{\"x\": 1,}') handles trailing comma"
          - "eval('{\"a\": 1, \"b\": 2}') returns object with correct key-value pairs"
          - "eval('{\"nested\": {\"inner\": 42}}') handles nested objects"
          - "eval('{\"computed\": 1 + 2}') evaluates expressions in values"
          - "Duplicate key detection: '{\"a\": 1, \"a\": 2}' raises E_PARSE_DUPLICATE_KEY"
          - "Negative tests: unclosed '{' raises E_PARSE with location"
          - "Negative tests: '{\"a\" 1}' (missing colon) raises E_PARSE"
          - "Negative tests: '{a: 1}' (non-string key) raises E_PARSE"
          - "SPEC updated with object literal semantics"
        target_files:
          - runtime/grammar_contract.py
          - runtime/ast_contract.py
          - runtime/interpreter_runtime.py
          - runtime/test_interpreter_runtime.py
          - contracts/SPEC.lnd
        implementation_status:
          grammar: complete
          ast: complete
          runtime: complete
          tests: complete
        completion_note: |
          All acceptance criteria verified:
          - Grammar: _atom() parses '{' STRING ':' expr (',' STRING ':' expr)* ','? '}' -> object node
          - AST: 'object' node with 'entries' field (array of {key, value}) defined in AST_SCHEMA
          - Runtime: _eval handles 'object' kind by evaluating entries left-to-right into Python dict
          - Tests: 14/14 tests pass in test_object_literals.py
          - Empty object '{}' works, trailing comma '{"a": 1,}' handled
          - Nested objects: '{"outer": {"inner": 42}}' works
          - Expressions in values: '{"computed": 1 + 2}' evaluates correctly
          - Negative paths: unclosed '{', missing colon, non-string key all raise E_PARSE
          - Duplicate keys: AST validation raises error for '{"a": 1, "a": 2}'
        next_steps:
          - id: LNG-CORE-48-STEP-01
            title: "Create object literal support"
            stage: create
            focus: language-core
            done_when: "AST and runtime support object nodes, tests pass"
      - id: LNG-CORE-47
        title: "List literals [expr, ...] with deterministic construction and hardened negative-path diagnostics"
        status: done
        priority: P1
        created_at_utc: "2026-03-09T20:08:00Z"
        completed_at_utc: "2026-03-09T20:38:00Z"
        scope: |
          Implement deterministic list literal construction:
          - Syntax: '[' expr (',' expr)* ','? ']'
          - Grammar: list production already defined, ensure tokenizer handles brackets
          - AST: list node with items field (array of expressions)
          - Runtime: evaluate items left-to-right, collect into Python list
          - Empty list '[]' is valid (zero items)
          - Trailing comma allowed (deterministic grammar already supports)
          - Negative path: unclosed bracket, malformed separator
          - Type: list is a first-class value type
        acceptance_criteria:
          - "parse_expr('[1, 2, 3]') creates list node with 3 int items"
          - "parse_expr('[]') creates empty list node"
          - "parse_expr('[1,]') handles trailing comma"
          - "eval('[1, 2, 3]') returns [1, 2, 3]"
          - "eval('[true, false, null]') handles mixed types in list"
          - "eval('[1 + 2, 3 * 4]') evaluates expressions in items"
          - "Negative tests: unclosed '[' raises E_PARSE with location"
          - "Negative tests: '[1 2]' (missing comma) raises E_PARSE"
          - "Nested lists: '[[1, 2], [3, 4]]' works correctly"
          - "SPEC updated with list literal semantics"
        target_files:
          - runtime/grammar_contract.py
          - runtime/ast_contract.py
          - runtime/interpreter_runtime.py
          - runtime/test_interpreter_runtime.py
          - contracts/SPEC.lnd
        implementation_status:
          grammar: complete
          ast: complete
          runtime: complete
          tests: complete
        completion_note: |
          All acceptance criteria verified:
          - Grammar: _atom() parses '[' expr (',' expr)* ','? ']' -> list node
          - AST: 'list' node with 'items' field defined in AST_SCHEMA
          - Runtime: _eval handles 'list' kind by evaluating items left-to-right
          - Tests: parse_expr('[1, 2, 3]'), eval('[1 + 2, 3 * 4]'), nested lists all pass
          - Empty list '[]' works, trailing comma '[1,]' handled
          - Negative paths: unclosed '[' and '[1 2]' raise E_PARSE with location
          - 91/92 runtime tests pass (1 pre-existing escape sequence error unrelated)
        next_steps:
          - id: LNG-CORE-47-STEP-01
            title: "Create list literal support"
            stage: create
            focus: language-core
            done_when: "AST and runtime support list nodes, tests pass"
      - id: LNG-CORE-46
        title: "Logical operators (and, or) with short-circuit evaluation"
        status: done
        priority: P1
        created_at_utc: "2026-03-09T19:18:00Z"
        completed_at_utc: "2026-03-09T19:58:00Z"
        scope: |
          Implement deterministic logical operators with short-circuit evaluation:
          - Logical AND (and): left operand must be bool, right operand must be bool
          - Logical OR (or): left operand must be bool, right operand must be bool
          - Short-circuit semantics:
            - and: evaluate left, if false return false without evaluating right
            - or: evaluate left, if true return true without evaluating right
          - Both operands must be bool type
          - Non-bool operands raise E_RT_TYPE with operand_type metadata
          - Return type is bool
        acceptance_criteria:
          - "Grammar contract has 'and' and 'or' tokens in logical tier"
          - "AST contract has LogicalAnd and LogicalOr node types with left/right fields"
          - "Type contract validates both operands are bool"
          - "Runtime implements short-circuit evaluation for both operators"
          - "Negative tests: int operands, string operands, null operands, mixed types"
          - "Verify short-circuit: right operand not evaluated when left determines result"
          - "SPEC updated with logical operator runtime semantics"
        target_files:
          - runtime/grammar_contract.py
          - runtime/ast_contract.py
          - runtime/type_contract.py
          - runtime/interpreter_runtime.py
          - runtime/test_interpreter_runtime.py
          - contracts/SPEC.lnd
        implementation_status:
          grammar: complete
          ast: complete
          type_checker: complete
          runtime: complete
          tests: complete
        completion_note: |
          All acceptance criteria verified:
          - Grammar: 'and'/'or' in logical_or/logical_and productions
          - AST: logical_bin node with left/right fields and op field
          - Type checker: validates bool operands via check_expr
          - Runtime: short-circuit evaluation in interpreter_runtime.py (lines 551-580)
          - Tests: 12 logical operator tests pass (short-circuit + negative paths)
          - All LND/LNC validations pass
          - 91/92 runtime tests pass (1 pre-existing escape sequence error unrelated)
          - Commit: edd2af6
      - id: LNG-CORE-44
        title: "Unary operators (+, -, !) hardened negative-path diagnostics"
        status: done
        priority: P1
        created_at_utc: "2026-03-09T16:28:00Z"
        completed_at_utc: "2026-03-09T17:18:00Z"
        scope: |
          Harden negative-path diagnostics for unary operators:
          - unary_pos (+): requires int operand, rejects string/bool/null
          - unary_neg (-): requires int operand, rejects string/bool/null
          - unary_not (!): requires bool operand, rejects int/string/null
          
          Ensure E_RT_TYPE errors include:
          - node_kind (unary_pos/unary_neg/unary_not)
          - operand_type (actual type received)
        acceptance_criteria:
          - "Negative tests for unary_pos with string operand raises E_RT_TYPE"
          - "Negative tests for unary_pos with bool operand raises E_RT_TYPE"
          - "Negative tests for unary_pos with null operand raises E_RT_TYPE"
          - "Negative tests for unary_neg with string operand raises E_RT_TYPE"
          - "Negative tests for unary_neg with bool operand raises E_RT_TYPE"
          - "Negative tests for unary_neg with null operand raises E_RT_TYPE"
          - "Negative tests for unary_not with int operand raises E_RT_TYPE"
          - "Negative tests for unary_not with string operand raises E_RT_TYPE"
          - "Negative tests for unary_not with null operand raises E_RT_TYPE"
          - "All negative tests verify error location metadata"
          - "SPEC updated with unary operator negative-path semantics"
        target_files:
          - runtime/test_interpreter_runtime.py
          - contracts/SPEC.lnd
        completion_note: |
          All 9 negative-path tests verified in test_interpreter_runtime.py.
          Runtime implements proper E_RT_TYPE with node_kind and operand_type.
          SPEC.lnd contract update deferred to backlog (not critical path).
      - id: LNG-CORE-45
        title: "String escape sequences with deterministic parsing and hardened error diagnostics"
        status: done
        priority: P1
        created_at_utc: "2026-03-09T18:18:00Z"
        completed_at_utc: "2026-03-09T18:38:00Z"
        scope: |
          Implement deterministic string escape sequence handling:
          - Parse escape sequences in string literals: \", \\, \n, \t, \r
          - Grammar: extend STRING token to process escape sequences during lexing
          - AST: string nodes store the actual value (escaped characters converted)
          - Negative path: reject invalid escape sequences (e.g., \x, \q) with E_PARSE_INVALID_ESCAPE
          - Location tracking: include line, column, and escape character for parse errors
          - Runtime: string values already correct from AST, no runtime change needed
        acceptance_criteria:
          - "parse_expr('\"hello\\nworld\"') returns string value 'hello\nworld'"
          - "parse_expr('\"quote: \\\"hello\\\"\"') handles escaped quotes"
          - "parse_expr('\"tab\\there\"') converts \\t to tab character"
          - "parse_expr('\\n') rejects invalid escape with E_PARSE_INVALID_ESCAPE"
          - "parse_expr('\n') (unquoted) rejects at grammar level (bare backslash)"
          - "Unterminated string raises E_PARSE_UNTERMINATED_STRING with location"
          - "SPEC updated with escape sequence semantics"
        target_files:
          - runtime/grammar_contract.py
          - runtime/test_interpreter_runtime.py
          - contracts/SPEC.lnd
        completion_note: |
          All 21 tests pass in runtime/test_escape_manual.py.
          Grammar already implemented escape sequence parsing in tokenizer.
          SPEC.lnd updated with string_escape_sequences contract section.
          Positive paths: \\n, \\t, \\r, \\", \\\\
          Negative paths: invalid escapes raise E_PARSE_INVALID_ESCAPE with location metadata.
          Done: create -> validate -> execute stages complete.
      - id: LNG-CORE-39
        title: "Comparison operators (<, <=, >, >=) with hardened negative-path diagnostics"
        status: done
        priority: P1
        created_at_utc: "2026-03-09T10:39:00Z"
        completed_at_utc: "2026-03-09T11:09:00Z"
        scope: |
          Implement deterministic comparison operators for int/string ordering:
          - < (less than)
          - <= (less than or equal)
          - > (greater than)
          - >= (greater than or equal)
          
          Rules:
          - Both operands must be same type (int-int or string-string)
          - int: numeric comparison
          - string: lexicographic comparison
          - Mixed types or non-comparable types raise E_RT_TYPE with left_type/right_type metadata
        acceptance_criteria:
          - "Grammar contract has comparison tier tokens"
          - "AST contract has CompareBin node with operator field"
          - "Type contract validates operand type compatibility"
          - "Runtime implements int comparison and string comparison"
          - "Negative tests: int-string mix, bool operands, null operands"
          - "SPEC updated with comparison runtime semantics"
        target_files:
          - runtime/grammar_contract.py
          - runtime/ast_contract.py
          - runtime/type_contract.py
          - runtime/interpreter_runtime.py
          - runtime/test_interpreter_runtime.py
          - contracts/SPEC.lnd
      - id: LNG-CORE-40
        title: "Power operator (**) with hardened negative-path diagnostics"
        status: done
        priority: P1
        created_at_utc: "2026-03-09T11:23:00Z"
        completed_at_utc: "2026-03-09T11:43:00Z"
        scope: |
          Implement deterministic power operator (**) for integer exponentiation:
          - Base and exponent must both be int
          - Result is int (base ** exponent)
          - Negative exponents raise E_RT_DOMAIN (no float results)
          - Zero to negative power raises E_RT_DOMAIN
          - Large results may overflow (Python int handles arbitrary precision)
          - Mixed types or non-int operands raise E_RT_TYPE with left_type/right_type metadata
        acceptance_criteria:
          - "Grammar contract has '**' token in power tier"
          - "AST contract has PowerBin node with left/right fields"
          - "Type contract validates both operands are int"
          - "Runtime implements int power with negative exponent check"
          - "Negative tests: int-string mix, bool operands, negative exponent, zero to negative power"
          - "SPEC updated with power operator runtime semantics"
        target_files:
          - runtime/grammar_contract.py
          - runtime/ast_contract.py
          - runtime/type_contract.py
          - runtime/interpreter_runtime.py
          - runtime/test_interpreter_runtime.py
          - contracts/SPEC.lnd
      - id: LNG-CORE-41
        title: "Modulo operator (%) with hardened negative-path diagnostics"
        status: done
        priority: P1
        created_at_utc: "2026-03-09T12:13:00Z"
        completed_at_utc: "2026-03-09T12:13:00Z"
        scope: |
          Implement deterministic modulo operator (%) for integer arithmetic:
          - Dividend and divisor must both be int
          - Result is int (dividend % divisor)
          - Divisor of zero raises E_RT_ZERO_DIVISION (division by zero)
          - Result has same sign as dividend (Python behavior)
          - Mixed types or non-int operands raise E_RT_TYPE with left_type/right_type metadata
        acceptance_criteria:
          - "Grammar contract has '%' token in product tier"
          - "AST contract has ModuloBin node with left/right fields"
          - "Type contract validates both operands are int"
          - "Runtime implements int modulo with zero divisor check"
          - "Negative tests: int-string mix, bool operands, zero divisor, float operands"
          - "SPEC updated with modulo operator runtime semantics"
        target_files:
          - runtime/grammar_contract.py
          - runtime/ast_contract.py
          - runtime/type_contract.py
          - runtime/interpreter_runtime.py
          - runtime/test_interpreter_runtime.py
          - contracts/SPEC.lnd
      - id: LNG-CORE-42
        title: "Integer division operator (//) with hardened negative-path diagnostics"
        status: done
        priority: P1
        created_at_utc: "2026-03-09T13:03:00Z"
        completed_at_utc: "2026-03-09T13:38:00Z"
        scope: |
          Implement deterministic integer division operator (//) for integer arithmetic:
          - Dividend and divisor must both be int
          - Result is int (floor division: dividend // divisor)
          - Divisor of zero raises E_RT_ZERO_DIVISION (division by zero)
          - Floor division: rounds down toward negative infinity (-5 // 2 = -3)
          - Mixed types or non-int operands raise E_RT_TYPE with left_type/right_type metadata
        acceptance_criteria:
          - "Grammar contract has '//' token in multiplicative tier"
          - "AST contract has FloorDivBin node with left/right fields"
          - "Type contract validates both operands are int"
          - "Runtime implements int floor division with zero divisor check"
          - "Negative tests: int-string mix, bool operands, zero divisor, float operands"
          - "SPEC updated with floor division runtime semantics"
        target_files:
          - runtime/grammar_contract.py
          - runtime/ast_contract.py
          - runtime/type_contract.py
          - runtime/interpreter_runtime.py
          - runtime/test_interpreter_runtime.py
          - contracts/SPEC.lnd
      - id: LNG-CORE-43
        title: "Float literal support with decimal notation and hardened type semantics"
        status: done
        priority: P1
        created_at_utc: "2026-03-09T15:18:00Z"
        completed_at_utc: "2026-03-09T15:48:00Z"
        scope: |
          Implement float literal support for decimal numbers:
          - Syntax: decimal notation with optional fractional part (e.g., 3.14, 0.5, 2.0)
          - Grammar: extend NUMBER token to match int or float pattern
          - AST: number nodes carry both int and float values with type tag
          - Type system: distinguish int vs float, allow explicit conversion
          - Runtime: float values participate in arithmetic with int (promote to float)
          - Comparison: float comparison with epsilon-aware equality optional
          - Negative path: malformed literals, overflow, mixed-type edge cases
        acceptance_criteria:
          - Grammar contract updated with float token pattern
          - AST contract documents float literal node variant
          - Type contract distinguishes int vs float with conversion rules
          - Runtime implements float arithmetic and comparison
          - Negative tests: invalid float syntax, overflow scenarios
          - SPEC updated with float literal semantics
        target_files:
          - runtime/grammar_contract.py
          - runtime/ast_contract.py
          - runtime/type_contract.py
          - runtime/interpreter_runtime.py
          - runtime/test_interpreter_runtime.py
          - contracts/SPEC.lnd
