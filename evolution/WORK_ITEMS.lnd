@lnd 0.2
version: 6
document: WORK_ITEMS
purpose: Canonical machine-readable backlog for coordinator-driven execution.
updated_at_utc: 2026-03-08T15:18:00Z

selection_policy:
  per_cycle_execution_limit: 1
  default_pick_order:
    - highest_priority
    - open_status
    - deterministic_id_order

allowed_status_values:
  - open
  - in_progress
  - blocked
  - done

buckets:
  language-core:
    description: Core syntax/AST/type contracts.
    items:
      - id: LNG-CORE-21
        title: Add deterministic null-coalescing operator (??) across grammar/AST/type/runtime contracts
        priority: P1
        status: open
        deterministic_scope: "Introduce right-associative null-coalescing expression tier between logical-or and ternary with deterministic parse and eval semantics."
        single_cycle_feasibility: true
        explicit_tests:
          - python3 -m unittest runtime.test_grammar_contract runtime.test_ast_contract runtime.test_type_contract runtime.test_interpreter_runtime
          - python3 scripts/lnd_validate.py contracts
          - python3 scripts/lnc_validate.py runtime
        product_effect_target: language_core_capability
        done_when:
          - "grammar_contract emits deterministic AST for chained coalescing (a ?? b ?? c) with stable right-associative shape"
          - "type_contract enforces compatible branch typing and deterministic null propagation behavior"
          - "interpreter_runtime evaluates ?? deterministically and short-circuits on non-null lhs"
          - "SPEC.lnd documents coalescing precedence and semantics"
  ecosystem:
    description: Tooling, docs, release, and onboarding surface for external use.
    items:
  practical-value:
    description: Real-world utility, examples, and measurable task value.
    items:
  interpreter-runtime:
    description: Deterministic interpreter/runtime behavior.
    items:
  validation:
    description: Tests, contracts, and property checks.
    items:
  integration:
    description: End-to-end runtime integration and replay checks.
    items:
