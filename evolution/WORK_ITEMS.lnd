@lnd 0.2
version: 6
document: WORK_ITEMS
purpose: Canonical machine-readable backlog for coordinator-driven execution.
updated_at_utc: 2026-03-08T15:58:00Z

selection_policy:
  per_cycle_execution_limit: 1
  default_pick_order:
    - highest_priority
    - open_status
    - deterministic_id_order

allowed_status_values:
  - open
  - in_progress
  - blocked
  - done

buckets:
  language-core:
    description: Core syntax/AST/type contracts.
    items:
      - id: LNG-CORE-23
        title: Add deterministic optional-chaining operator (?.) for safe object member access across grammar/AST/type/runtime contracts
        priority: P1
        status: open
        deterministic_scope: "Introduce optional-chaining member access for object field reads only (no optional calls/writes), short-circuiting to null when base is null and preserving strict errors for non-object, non-null bases."
        explicit_tests:
          - python3 -m unittest runtime.test_grammar_contract runtime.test_ast_contract runtime.test_type_contract runtime.test_interpreter_runtime
          - python3 scripts/lnd_validate.py evolution
          - python3 scripts/lnd_validate.py contracts
          - python3 scripts/lnd_validate.py formats
          - python3 scripts/lnc_validate.py runtime
        product_effect_target: runtime_py_changed
        done_when:
          - grammar includes deterministic optional-chaining token and precedence with member-access compatibility
          - AST/type contracts include OptionalMemberAccess node invariants
          - runtime evaluator short-circuits null base to null deterministically without evaluating invalid field reads
          - SPEC updated with optional-chaining semantics and error codes
  ecosystem:
    description: Tooling, docs, release, and onboarding surface for external use.
    items:
  practical-value:
    description: Real-world utility, examples, and measurable task value.
    items:
  interpreter-runtime:
    description: Deterministic interpreter/runtime behavior.
    items:
  validation:
    description: Tests, contracts, and property checks.
    items:
  integration:
    description: End-to-end runtime integration and replay checks.
    items:
