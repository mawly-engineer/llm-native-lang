@lnd 0.2
version: 25
document: WORK_ITEMS
purpose: Canonical machine-readable backlog for coordinator-driven execution.
updated_at_utc: 2026-03-10T13:52:00Z

selection_policy:
  per_cycle_execution_limit: 3
  batch_by_stage_type: true
  lightweight_stages:
    - spec_update
    - doc_tweak
    - governance_note
  default_pick_order:
    - highest_priority
    - open_status
    - deterministic_id_order

allowed_status_values:
  - open
  - in_progress
  - blocked
  - done

buckets:
  language-core:
    description: Core syntax/AST/type contracts.
    items:
      - id: LNG-CORE-60
        title: Range expressions with step (range(start, end, step))
        status: open
        priority: P1
        created_at: "2026-03-10T13:52:00Z"
        description: |
          Implement range expressions for generating numeric sequences.
          Syntax: range(end) | range(start, end) | range(start, end, step)
          Returns a list of integers from start (inclusive) to end (exclusive).
          Supports negative step for descending sequences.
          Essential for list iteration, indexing, and list comprehensions.
        acceptance:
          - AST node kind "range_call" added to ast_contract.py
          - Runtime implements range evaluation with bounds checking
          - Supports single-argument form: range(5) -> [0, 1, 2, 3, 4]
          - Supports two-argument form: range(1, 5) -> [1, 2, 3, 4]
          - Supports three-argument form: range(0, 10, 2) -> [0, 2, 4, 6, 8]
          - Supports negative step: range(5, 0, -1) -> [5, 4, 3, 2, 1]
          - Zero step raises E_RT_RANGE_STEP_ZERO
          - Empty ranges return []: range(5, 5) -> []
          - Works with variables: range(x, y, z)
        target_files:
          - runtime/ast_contract.py
          - runtime/interpreter_runtime.py
          - runtime/test_range.py (new)
      - id: LNG-CORE-59
        title: List slicing operator [start:end:step]
        status: done
        priority: P1
        created_at: "2026-03-10T12:22:00Z"
        completed_at: "2026-03-10T13:22:00Z"
        description: |
          Implement list slicing with Python-style slice notation [start:end:step].
          Supports negative indices, optional bounds, and step values.
          Required by SPEC v1.0.0 grammar for list operations.
        acceptance:
          - AST node kind "slice" added to ast_contract.py
          - Runtime implements slice evaluation with bounds checking
          - Supports negative indices (e.g., [-1] for last element)
          - Supports optional start/end (e.g., [:5], [2:])
          - Supports step parameter (e.g., [::2], [::-1])
          - Tests cover edge cases: empty slices, out of bounds, negative step
        target_files:
          - runtime/ast_contract.py
          - runtime/interpreter_runtime.py
          - runtime/test_list_slicing.py (new)
  ecosystem:
    description: Tooling, docs, release, and onboarding surface for external use.
    items: []
  practical-value:
    description: Real-world utility, examples, and measurable task value.
    items: []
  interpreter-runtime:
    description: Deterministic interpreter/runtime behavior.
    items: []
  validation:
    description: Tests, contracts, and property checks.
    items: []
  integration:
    description: End-to-end runtime integration and replay checks.
    items: []
