@lnd 0.2
kind: contract_spec
id: TYPE-SYSTEM-001
schema_id: llm_native_lang.type_system
schema_version: 1.0.0
status: active
updated_at_utc: 2026-03-07T13:36:00Z
project: llm-native-lang
purpose: Structural node and edge typing constraints with deterministic graph invariants.

node_contract:
  required_fields:
    - id
    - type
  attrs_type: object
  attr_key_regex: '^[A-Za-z_][A-Za-z0-9_.-]*$'
  reserved_attr_keys:
    - id
    - type

edge_contract:
  required_fields:
    - from
    - to
    - contract

graph_invariants:
  - node_id_must_be_unique
  - edge_endpoints_must_resolve
  - node_removal_blocked_if_any_edge_references_node
