@lnd 0.2
kind: migration_plan
id: LNG-MIG-001
title: Migrate repository to .lnd (docs) and .lnc (code)
status: open
updated_at_utc: 2026-03-07T12:23:00Z
goal: Move project contracts and executable artifacts to split deterministic formats without breaking current delivery flow.

principles:
  - staged_rollout
  - zero_big_bang
  - deterministic_output
  - backward_compatibility_during_transition
  - reversible_steps

phase_1_control_docs_first:
  objective: Convert coordinator-driving docs to .lnd first.
  targets:
    - docs/AGENT_ROUTER.md
    - docs/LANGUAGE_BACKLOG.md
    - docs/NEXT_STEPS.md
    - docs/SUPERVISOR_STATE.md
    - docs/SUPERVISOR_PROFILES.md
    - docs/CYCLE_LOG.md
  outputs:
    - equivalent .lnd files with stable key order
    - compatibility note in old .md files
  done_when:
    - coordinator can read .lnd as source of truth
    - old .md kept as mirrors or pointers

phase_2_execution_contracts:
  objective: Move core specs/contracts from markdown to .lnd.
  targets:
    - docs/SPEC.md
    - docs/RUNTIME.md
    - docs/RUNTIME_CONTRACT.md
    - docs/PATCH_FORMAT.md
    - docs/UI_DIFF_PROTOCOL.md
    - docs/TYPE_SYSTEM.md
  outputs:
    - .lnd contract versions
    - explicit schema IDs and version tags
  done_when:
    - contract checks consume .lnd definitions

phase_3_code_artifact_onboarding:
  objective: Introduce .lnc for executable/code-unit artifacts.
  targets:
    - runtime/examples/
    - deterministic IR fixtures
    - future generated code units
  outputs:
    - first canonical code_unit .lnc examples
    - parser/validator support for LNC_PROFILE.lnd
  done_when:
    - at least 3 production-relevant .lnc artifacts validated in CI

phase_4_tooling_ci:
  objective: Make migration enforceable.
  tasks:
    - add lnd_validate and lnc_validate commands
    - add canonical formatter checks
    - add profile-mismatch detection
    - add fixture conformance tests
  done_when:
    - CI fails on invalid .lnd/.lnc
    - stable error codes used in all failures

phase_5_deprecation_cleanup:
  objective: Retire transitional duplicates.
  tasks:
    - remove obsolete mirrored .md where safe
    - keep only human-facing READMEs in markdown
    - freeze migration map
  done_when:
    - source-of-truth paths are unambiguous
    - migration status marked done

risk_controls:
  - keep md_mirrors_until_ci_green
  - one_subsystem_per_pr
  - run_focused_tests_per_phase
  - fallback_branch_tag_each_phase

tracking_metrics:
  - percent_docs_in_lnd
  - percent_code_artifacts_in_lnc
  - ci_validation_pass_rate
  - profile_mismatch_error_count

next_actions:
  - create LNG-ECO-05: phase_1 control docs migration
  - create LNG-ECO-06: validator tooling scaffold
  - wire CI gate after first validator pass
