@lnd 0.2
kind: runtime_contract
id: LNG-RUNTIME-001
status: active
version: 1.0.0
updated_at_utc: 2026-03-10T10:52:00Z
purpose: Runtime API and replay semantics contract for llm-native-lang.

runtime_api:
  eval: eval(source: str) -> Value
  parse: parse(source: str) -> AST
  check: check(ast: AST) -> Type

replay_support:
  capture_execution_state: capture_execution_state() -> ExecutionState
  replay_from_state: replay_from_state(state: ExecutionState) -> Value
  serialize_trace: serialize_trace(trace: Trace) -> JSON

deterministic_requirements:
  - same_input_same_state_produces_same_output
  - no_external_io_during_replay
  - fuel_based_resource_limits

execution_state:
  - environment_bindings
  - call_stack
  - fuel_remaining

error_codes:
  E_RT_FUEL_EXHAUSTED: Execution exceeded fuel limit
  E_RT_TYPE: Runtime type error
  E_RT_ARITY_MISMATCH: Argument count mismatch
