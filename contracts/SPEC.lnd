@lnd 0.2
kind: contract_spec
id: SPEC-001
schema_id: llm_native_lang.spec
schema_version: 1.0.0
status: active
updated_at_utc: 2026-03-09T11:09:00Z
project: llm-native-lang
objective: Deterministic language runtime plus deterministic DAG-based UI replay.

core_entities:
  - ProgramGraph
  - Revision
  - UITimelineEvent
  - UISnapshot

primary_outputs:
  - machine_readable_schema_documents
  - test_verified_runtime_behavior
  - append_only_cycle_execution_records

language_minimal_grammar:
  version: 1.0.0
  start: expr
  required_nonterminals:
    - expr
    - let
    - if
    - fn
    - coalesce
    - logical_or
    - logical_and
    - equality
    - comparison
    - concat
    - multiplicative
    - power
    - unary
    - postfix
    - atom
    - list
    - params
    - args
  productions:
    - "expr -> let | if | fn | coalesce"
    - "let -> 'let' IDENT '=' expr 'in' expr"
    - "if -> 'if' expr 'then' expr 'else' expr"
    - "fn -> 'fn' '(' params? ')' '=>' expr"
    - "coalesce -> logical_or ('??' coalesce)?"
    - "logical_or -> logical_and ('or' logical_and)*"
    - "logical_and -> equality ('and' equality)*"
    - "equality -> comparison (('==' | '!=') comparison)*"
    - "comparison -> concat (('<' | '<=' | '>' | '>=') concat)*"
    - "concat -> multiplicative (('+' | '-') multiplicative)*"
    - "multiplicative -> power (('*' | '/' | '%' | '//') power)*"
    - "power -> unary ('**' power)?"
    - "unary -> '+' unary | '-' unary | '!' unary | postfix"
    - "postfix -> atom (call_suffix | optional_call_suffix | index_suffix | optional_index_suffix | member_suffix)*"
    - "call_suffix -> '(' args? ')'"
    - "optional_call_suffix -> '?(' args? ')'"
    - "index_suffix -> '[' expr ']'"
    - "optional_index_suffix -> '?[' expr ']'"
    - "member_suffix -> '.' IDENT | '?.' IDENT"
    - "atom -> 'true' | 'false' | 'null' | STRING | IDENT | NUMBER | list | object | '(' expr ')'"
    - "list -> '[' args? ']'"
    - "object -> '{' object_entries? '}'"
    - "object_entries -> object_entry (',' object_entry)* ','?"
    - "object_entry -> STRING ':' expr"
    - "params -> IDENT (',' IDENT)* ','?"
    - "args -> expr (',' expr)* ','?"

language_runtime_semantics:
  if_expression:
    operator: "if <cond> then <then_expr> else <else_expr>"
    scope: deterministic_branch_selection
    behavior:
      - evaluate_condition_once
      - require_condition_type_bool_or_raise_E_RT_TYPE
      - evaluate_only_selected_branch
  multiplicative_operators:
    operators:
      - "*"
      - "/"
      - "%"
      - "//"
    scope: deterministic_integer_multiplicative_arithmetic
    behavior:
      - multiply_both_operands_int_then_multiply
      - exact_division_both_operands_int_then_require_divisible_else_E_RT_DOMAIN
      - modulo_both_operands_int_then_modulo
      - int_div_both_operands_int_then_floor_divide
      - division_or_modulo_by_zero_raise_E_RT_ZERO_DIVISION
      - mixed_or_unsupported_types_raise_E_RT_TYPE
  additive_operators:
    operators:
      - "+"
      - "-"
    scope: deterministic_string_concat_and_number_arithmetic
    behavior:
      - plus_both_operands_string_then_concat
      - plus_both_operands_int_then_add
      - minus_both_operands_int_then_subtract
      - mixed_or_unsupported_types_raise_E_RT_TYPE
  object_literal:
    operator: "{\"key\": expr, ...}"
    scope: deterministic_object_construction
    behavior:
      - evaluate_entries_left_to_right
      - keys_must_be_string_literals
      - duplicate_keys_rejected_by_ast_contract
      - resulting_value_is_object_mapping
  index_access:
    operator: "[expr]"
    scope: list_and_object_reads_only
    behavior:
      - if_target_is_list_require_integer_index_and_bounds_check
      - if_target_is_object_require_string_key
      - if_object_key_missing_raise_E_RT_MISSING_MEMBER
      - if_target_is_other_type_raise_E_RT_TYPE
  optional_index_access:
    operator: "?[expr]"
    scope: list_and_object_reads_with_null_short_circuit
    behavior:
      - evaluate_base_expression_once
      - if_base_is_null_return_null
      - if_base_is_list_require_integer_index_and_bounds_check
      - if_base_is_object_require_string_key
      - if_object_key_missing_raise_E_RT_MISSING_MEMBER
      - if_base_is_non_collection_non_null_raise_E_RT_TYPE
  optional_member_access:
    operator: "?."
    scope: object_field_reads_only
    behavior:
      - evaluate_base_expression_once
      - if_base_is_null_return_null
      - if_base_is_object_read_member
      - if_base_is_non_object_non_null_raise_E_RT_TYPE
      - if_member_missing_raise_E_RT_MISSING_MEMBER
  optional_call:
    operator: "?(...)"
    scope: callable_invocation_with_null_short_circuit
    behavior:
      - evaluate_target_expression_once
      - if_target_is_null_return_null_without_evaluating_args
      - if_target_is_closure_or_callable_invoke_with_args
      - if_callable_arity_mismatch_raise_E_RT_ARITY_MISMATCH_or_E_RT_HOST_CALL_ARITY
      - if_target_is_non_callable_non_null_raise_E_RT_NOT_CALLABLE
  comparison_operators:
    operators:
      - "<"
      - "<="
      - ">"
      - ">="
      - "=="
      - "!="
    scope: deterministic_ordering_and_equality_comparison
    behavior:
      - ordering_less_than_both_operands_int_then_numeric_compare
      - ordering_less_than_both_operands_string_then_lexicographic_compare
      - ordering_less_than_or_equal_both_operands_int_then_numeric_compare
      - ordering_less_than_or_equal_both_operands_string_then_lexicographic_compare
      - ordering_greater_than_both_operands_int_then_numeric_compare
      - ordering_greater_than_both_operands_string_then_lexicographic_compare
      - ordering_greater_than_or_equal_both_operands_int_then_numeric_compare
      - ordering_greater_than_or_equal_both_operands_string_then_lexicographic_compare
      - equality_both_operands_same_type_int_then_numeric_equality
      - equality_both_operands_same_type_bool_then_boolean_equality
      - equality_both_operands_same_type_string_then_lexicographic_equality
      - equality_both_operands_same_type_null_then_null_equality
      - ordering_mixed_types_or_unsupported_operand_types_raise_E_RT_TYPE_with_left_type_right_type_metadata
      - equality_mismatched_operand_types_raise_E_RT_TYPE_with_left_type_right_type_metadata
      - equality_unsupported_operand_types_raise_E_RT_TYPE_with_side_and_type_metadata

non_goals:
  - human_first_prose_as_primary_system_interface
  - ambiguous_process_narration
